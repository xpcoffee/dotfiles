{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "mcp__ado__*",
      "mcp__grafana__*",
      "mcp__github__*",
      "mcp__dev-services__*",
      "mcp__nvim-markdown-notes-memgraph__*",
      "mcp__playwright__*",
      "WebFetch",
      "WebSearch",
      "Bash(QUERY=* az monitor log-analytics query *)",
      "Edit(//home/emerick/code/work/)",
      "Edit(//home/emerick/code/personal/)",
      "Read(//home/emerick/code/work/)",
      "Read(//home/emerick/code/personal/)",
      "Bash(python3 -m http.server:*)",
      "Bash(jq *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(ps *)",
      "Bash(dotnet *)",
      "Bash(git *)",
      "Bash(git commit *)",
      "Bash(uv *)",
      "Bash(awk *)",
      "Bash(find *)",
      "Bash(echo *)",
      "Bash(grep *)",
      "Bash(tee *)",
      "Bash(test *)",
      "Bash(make *)",
      "Bash(sleep *)",
      "Bash(xargs *)",
      "Bash(tail *)",
      "Bash(pandoc *)",
      "Bash(docker compose *)",
      "Bash(docker build *)",
      "Bash(docker exec *)",
      "Bash(docker rm *)",
      "Bash(gh *)",
      "Bash(gh api *)",
      "Bash(gh * --jq *)"
    ],
    "deny": ["Read(./secrets/**)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // \"\"' | if grep -qE 'git\\s+commit'; then if grep -qE 'git\\s+commit.*\\$\\('; then echo 'ERROR: Command substitution $() detected in git commit' >&2; echo 'Use: git commit -m \"message\" or git commit -F- <<EOF' >&2; exit 2; elif grep -qE 'git\\s+commit.*`'; then echo 'ERROR: Backtick substitution detected' >&2; exit 2; elif grep -qE 'git\\s+commit.*<<<'; then echo 'ERROR: Heredoc syntax detected' >&2; exit 2; fi; fi"
          }
        ]
      }
    ]
  },
  "model": "opus",
  "enabledPlugins": {
    "nvim-markdown-notes-memgraph@xpcoffee-plugins": true
  },
  "spinnerTipsEnabled": false
}
