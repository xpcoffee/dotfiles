{
  "env": {
    "CLAUDE_ENV_FILE": "/home/rick/.claude_env"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "mcp__ado__*",
      "mcp__grafana__*",
      "mcp__github__*",
      "mcp__dev-services__*",
      "mcp__nvim-markdown-notes-memgraph__*",
      "mcp__playwright__*",
      "WebFetch",
      "WebSearch",
      "Bash(az:*)",
      "Edit(/tmp/**)",
      "Write(/tmp/**)",
      "Read(/tmp/**)",
      "Read(~/.claude/skills/**)",
      "Edit(/home/emerick/code/work/**)",
      "Write(/home/emerick/code/work/**)",
      "Read(/home/emerick/code/work/**)",
      "Edit(/home/emerick/code/personal/**)",
      "Write(/home/emerick/code/personal/**)",
      "Read(/home/emerick/code/personal/**)",
      "Bash(python3 -m http.server:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier:*)",
      "Bash(npx oxfmt:*)",
      "Bash(npx tsc:*)",
      "Bash(jq:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(ps:*)",
      "Bash(dotnet:*)",
      "Bash(git:*)",
      "Bash(uv:*)",
      "Bash(awk:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(tee:*)",
      "Bash(test:*)",
      "Bash(make:*)",
      "Bash(sleep:*)",
      "Bash(xargs:*)",
      "Bash(tail:*)",
      "Bash(pandoc:*)",
      "Bash(docker:*)",
      "Bash(gh:*)",
      "Bash(go test:*)",
      "Bash(gcloud:*)",
      "Bash(npm:*)",
      "Edit(\"/tmp/*\")",
      "Read(\"/tmp/*\")"
    ],
    "deny": [
      "Read(./secrets/**)"
    ],
    "defaultMode": "auto"
  },
  "model": "haiku",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // \"\"' | { read -r cmd; if echo \"$cmd\" | grep -qE 'git\\s+commit'; then if echo \"$cmd\" | grep -qE '\\$\\('; then echo 'BLOCKED: Command substitution $() not allowed in git commit. Use a heredoc with cat <<EOF instead.' >&2; exit 2; elif echo \"$cmd\" | grep -qE '`'; then echo 'BLOCKED: Backtick substitution not allowed in git commit. Use a heredoc with cat <<EOF instead.' >&2; exit 2; elif echo \"$cmd\" | grep -qE '<<<'; then echo 'BLOCKED: Heredoc syntax not allowed in git commit. Use a heredoc with cat <<EOF instead.' >&2; exit 2; fi; fi; }"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // \"\"' | { read -r cmd; if echo \"$cmd\" | grep -qE 'cd\\s+.*&&\\s*git'; then echo 'BLOCKED: Use git -C instead of cd && git (e.g., git -C /path/to/repo status)' >&2; exit 2; fi; }"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "nvim-markdown-notes-memgraph@xpcoffee-plugins": true,
    "redacted-plugin@redacted-marketplace": true,
    "oncall@redacted-marketplace": true,
    "software-design@redacted-marketplace": true,
    "writing-style@redacted-marketplace": true
  },
  "spinnerTipsEnabled": false,
  "skipAutoPermissionPrompt": true,
  "extraKnownMarketplaces": {
    "xpcoffee-notes": {
      "source": {
        "source": "directory",
        "path": "/home/rick/code/personal/notes"
      }
    }
  },
  "sandbox": {
    "filesystem": {
      "allowWrite": [
        "/home/emerick/code/work/**",
        "/home/emerick/code/personal/**"
      ],
      "allowRead": [
        "/home/emerick/code/work/**",
        "/home/emerick/code/personal/**"
      ]
    }
  },
  "spinnerTipsEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
