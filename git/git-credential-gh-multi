#!/usr/bin/env bash
# Routes git credential lookups to `gh` by username, supporting multiple
# logged-in accounts. Only handles `get`; `store`/`erase` are no-ops since
# `gh auth login` owns the token lifecycle.

[ "${1:-}" = "get" ] || exit 0

protocol=
host=
username=
while IFS='=' read -r key value; do
	[ -z "$key" ] && break
	case "$key" in
		protocol) protocol="$value" ;;
		host) host="$value" ;;
		username) username="$value" ;;
	esac
done

[ -n "$username" ] || exit 0
token=$(/usr/bin/gh auth token --user "$username" 2>/dev/null) || exit 0
[ -n "$token" ] || exit 0

cat <<EOF
protocol=$protocol
host=$host
username=$username
password=$token
EOF
